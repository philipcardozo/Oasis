__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.claude/
.DS_Store
.env
.env.*
!.env.example
vinst/
.venv/
env/
venv/
ENV/
*.tif

# Terrain tiles (all providers — large binary assets, regenerable)
graph/tiles/

# Generated universe payloads (rebuilt by expand_us.py)
graph/data/universe.json
graph/data/universe_bulk.json
graph/data/universe_core.json

# Generated UI payloads (rebuilt by refresh_all.py + build_map_geojson.py).
# hq_coords.json is intentionally NOT here: it is a geocode cache/input, not a
# pure output, and is expensive to rebuild (rate-limited ArcGIS geocoding).
graph/data/companies.geojson
graph/data/securities.geojson
graph/data/relationships.geojson
graph/data/graph-index.json
graph/data/filings.json
graph/data/news.json
graph/data/gov_contracts.json
graph/data/edge_candidates.json
graph/data/pol_members.json

# GLEIF LEI map (regenerable 18.7 MB download from refresh_gleif.py)
graph/data/sources_meta/lei_map.json

# Raw source downloads (regenerable; GLEIF golden copy, SEC, terrain, etc.)
data/raw/

# Parquet store — canonical query layer, regenerable via build_store.py (prompt 10)
data/store/

# Generated daily briefings (prompt 15)
outputs/briefings/

# SEC company facts cache (fetched on demand)
graph/data/companyfacts/

# Generated reports (rebuilt by dcf_export.py)
graph/data/reports/

# Diagnostic outputs (not served to the UI)
graph/data/dupes_report.json
graph/data/location_unknown.json

# Build outputs
outputs/

# Archived data files
archive/data/

# Media assets (large binary files)
Assets & Media/

# Playwright
node_modules/
test-results/
playwright-report/

# Local audit backups (never commit)
.local-backups/
